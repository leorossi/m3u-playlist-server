# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and takes precedence over .env.

# Symfony environment: dev, test, or prod
APP_ENV=dev

# Random secret used for CSRF tokens, cookies, etc. — generate with:
#   php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=

# Admin account created by doctrine:fixtures:load
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Database — SQLite (default) or any Doctrine-supported URL
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
